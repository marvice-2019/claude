    {
      "parameters": {
        "url": "=https://YOUR_N8N_URL/webhook/crm-action",
        "method": "POST",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Content-Type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "bodyContentType": "json",
        "body": "={\n  \"action\": \"CONFIRM_BOOKING\",\n  \"business_id\": \"{{$json.business_id}}\",\n  \"session_id\": \"{{$json.session_id}}\",\n  \"caller_number\": \"{{$json.caller_number}}\",\n  \"booking_data\": {{JSON.stringify($json.booking_data || {})}},\n  \"detected_language\": \"{{$json.detected_language}}\"\n}",
        "options": { "timeout": 10000 }
      },
      "id": "ch-041",
      "name": "Trigger CRM Booking",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 3,
      "position": [2640, 640]
    }
