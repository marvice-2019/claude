# ═══════════════════════════════════════════
# AI Voice Agent — Environment Configuration
# ═══════════════════════════════════════════
# Copy this to .env and fill in your actual values.
# NEVER commit the .env file with real credentials.

# ── n8n Configuration ──
N8N_BASE_URL=https://your-n8n-instance.com
N8N_ENCRYPTION_KEY=your-encryption-key

# ── Twilio (Voice Gateway) ──
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+91XXXXXXXXXX

# ── Deepgram (Speech-to-Text) ──
DEEPGRAM_API_KEY=your-deepgram-api-key

# ── ElevenLabs (Text-to-Speech — Primary) ──
ELEVENLABS_API_KEY=your-elevenlabs-api-key
ELEVENLABS_VOICE_ID=your-chosen-voice-id
# Recommended voices: "Rachel" (warm female), "Domi" (professional female)
# For Indian accent: Clone a voice or use multilingual_v2 model

# ── Azure TTS (Text-to-Speech — Fallback for Regional Languages) ──
AZURE_TTS_KEY=your-azure-speech-key
AZURE_TTS_REGION=centralindia
# Azure voices for Indian languages:
# Tamil: ta-IN-PallaviNeural
# Telugu: te-IN-ShrutiNeural
# Kannada: kn-IN-SapnaNeural
# Malayalam: ml-IN-SobhanaNeural
# English: en-IN-NeerjaNeural

# ── Anthropic (Claude AI Brain) ──
ANTHROPIC_API_KEY=your-anthropic-api-key
# Model: claude-sonnet-4-6 (fast + capable)
# Fallback: claude-haiku-4-5-20251001 (faster, simpler queries)

# ── Google Sheets (Data Storage) ──
GSHEET_ID=your-google-sheet-id
GOOGLE_API_KEY=your-google-api-key
# Required sheets: Bookings, Customers, ConversationLogs, BusinessConfig, OutboundQueue

# ── WhatsApp (WATI API) ──
WATI_API_KEY=your-wati-api-key
WATI_BASE_URL=https://live-server-108478.wati.io

# ── Business Configuration ──
DEFAULT_LANGUAGE=en
BUSINESS_TIMEZONE=Asia/Kolkata
MAX_SILENCE_RETRIES=3
CALL_TIMEOUT_SECONDS=300
ESCALATION_PHONE=+91XXXXXXXXXX
